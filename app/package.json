{
  "name": "fyadr-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "vite",
    "dev:web": "vite",
    "build": "tsc && vite build",
    "build:web": "tsc && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "check": "npm run check:text && npm run typecheck && npm run test:frontend",
    "check:text": "node ../scripts/run_python.mjs ../scripts/check_frontend_text.py",
    "test:frontend": "npm run test:frontend:state-consistency && npm run test:frontend:diff-virtualization && npm run test:frontend:review-save && npm run test:frontend:round-snapshot && npm run test:frontend:evidence && npm run test:frontend:model-streaming && npm run test:frontend:catalog-concurrency && npm run test:frontend:sidebar-navigation && npm run test:frontend:prompt-route-concurrency && npm run test:frontend:history-diagnostics",
    "test:frontend:state-consistency": "node ../scripts/frontend_state_consistency_regression.mjs",
    "test:frontend:diff-virtualization": "node ../scripts/frontend_diff_virtualization_regression.mjs",
    "test:frontend:review-save": "node ../scripts/frontend_review_save_queue_regression.mjs",
    "test:frontend:round-snapshot": "node ../scripts/frontend_round_snapshot_regression.mjs",
    "test:frontend:evidence": "node ../scripts/frontend_evidence_chain_regression.mjs",
    "test:frontend:model-streaming": "node ../scripts/frontend_model_streaming_regression.mjs",
    "test:frontend:catalog-concurrency": "tsx ../scripts/model_catalog_concurrency_regression.mjs",
    "test:frontend:sidebar-navigation": "node ../scripts/frontend_sidebar_navigation_regression.mjs",
    "test:frontend:prompt-route-concurrency": "node ../scripts/frontend_prompt_route_concurrency_regression.mjs",
    "test:frontend:history-diagnostics": "node ../scripts/frontend_history_diagnostics_integrity_regression.mjs",
    "test:e2e:smoke": "node --experimental-websocket ../scripts/browser_e2e_smoke.mjs",
    "capture:readme": "node --experimental-websocket ../scripts/capture_readme_assets.mjs"
  },
  "dependencies": {
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-virtual": "3.14.7",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.14.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^3.5.0",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.23.1",
    "typescript": "^5.5.4",
    "vite": "^8.1.5"
  }
}
