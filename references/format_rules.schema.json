{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "FYADR Word Format Rules",
  "type": "object",
  "required": ["version", "styles"],
  "properties": {
    "version": { "type": "integer", "minimum": 1 },
    "schoolName": { "type": "string" },
    "sourceSummary": { "type": "string" },
    "page": {
      "type": "object",
      "properties": {
        "paper": { "type": "string" },
        "topMarginCm": { "type": "number" },
        "bottomMarginCm": { "type": "number" },
        "leftMarginCm": { "type": "number" },
        "rightMarginCm": { "type": "number" }
      }
    },
    "styles": {
      "type": "object",
      "propertyNames": {
        "enum": [
          "toc_heading",
          "cn_abstract_lead",
          "en_abstract_lead",
          "cn_keywords",
          "en_keywords",
          "cn_abstract_body",
          "en_abstract_body",
          "heading_1",
          "heading_2",
          "heading_3",
          "heading_4",
          "body_text",
          "caption",
          "note",
          "table_text",
          "references_heading",
          "references_body",
          "ack_heading",
          "ack_body"
        ]
      },
      "additionalProperties": {
        "type": "object",
        "properties": {
          "cnFont": { "type": "string" },
          "enFont": { "type": "string" },
          "fontSizePt": { "type": "number" },
          "bold": { "type": ["boolean", "null"] },
          "italic": { "type": ["boolean", "null"] },
          "alignment": { "enum": ["left", "center", "right", "justify"] },
          "firstLineIndentPt": { "type": ["number", "null"] },
          "spaceBeforePt": { "type": "number" },
          "spaceAfterPt": { "type": "number" },
          "lineSpacingPt": { "type": ["number", "null"] },
          "lineSpacingMultiple": { "type": ["number", "null"] }
        }
      }
    },
    "styleMeta": {
      "type": "object",
      "propertyNames": {
        "enum": [
          "toc_heading",
          "cn_abstract_lead",
          "en_abstract_lead",
          "cn_keywords",
          "en_keywords",
          "cn_abstract_body",
          "en_abstract_body",
          "heading_1",
          "heading_2",
          "heading_3",
          "heading_4",
          "body_text",
          "caption",
          "note",
          "table_text",
          "references_heading",
          "references_body",
          "ack_heading",
          "ack_body"
        ]
      },
      "additionalProperties": {
        "type": "object",
        "properties": {
          "sourceText": { "type": "string" },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "isInferred": { "type": "boolean" }
        }
      }
    },
    "quality": {
      "type": "object",
      "properties": {
        "deterministicHits": { "type": "integer" },
        "requiredRoles": { "type": "array", "items": { "type": "string" } },
        "explicitRoles": { "type": "array", "items": { "type": "string" } },
        "inheritedRoles": { "type": "array", "items": { "type": "string" } },
        "defaultRoles": { "type": "array", "items": { "type": "string" } },
        "missingSourceRoles": { "type": "array", "items": { "type": "string" } },
        "lowConfidenceRoles": { "type": "array", "items": { "type": "string" } },
        "explicitCoveragePercent": { "type": "integer" },
        "usableCoveragePercent": { "type": "integer" },
        "warnings": { "type": "array", "items": { "type": "string" } },
        "suggestions": { "type": "array", "items": { "type": "string" } }
      }
    },
    "notes": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
