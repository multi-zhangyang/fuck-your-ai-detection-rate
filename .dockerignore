# ---------------------------------------------------------------------------
# FYADR .dockerignore — keep the build context small & secret-free.
# Anything matched here is NOT sent to the Docker daemon during `build`,
# so it cannot leak into the image and need not be copied.
# ---------------------------------------------------------------------------

# --- Node / frontend build artifacts & deps (Stage A does `npm ci`) ---
app/node_modules
app/dist
app/.vite
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- Python venv / caches (Stage B does `pip install`) ---
.venv
__pycache__
*.py[cod]
.pytest_cache
.mypy_cache
.coverage
htmlcov

# --- Generated runtime OUTPUT (state, not source) ---
data
finish
origin
logs
*.log
tmp
temp
uploads
reports
*.db
*.db-journal
*.sqlite
*.sqlite3
*.jsonl

# --- Local secrets / env (never bake into image) ---
.env
.env.*
app/.env
app/.env.*
!*.env.example
!app/*.env.example
*.key
*.pem
*.p12
*.crt
*.cert
*.token
*.secret

# --- Local docs / binaries / screenshots ---
*.doc
*.docx
*.docm
*.pdf
*.zip
*.7z
*.rar
*.tar
*.tar.gz
*.tgz
screenshots
playwright-report
test-results
app/ui-check*.png
app/current-ui-*.png
app/.codex-chrome-ui-refactor*
app/.codex-chrome-*

# --- Git / CI / editor ---
.git
.gitattributes
.github
.vscode
.idea
.agents
.DS_Store
Thumbs.db

# --- Regression / test scripts not needed at runtime ---
scripts/*_regression.py
scripts/browser_e2e_smoke.mjs
scripts/real_docx_smoke.py
scripts/round_concurrency_benchmark.py
scripts/pre_release_check*.py
scripts/open_source_audit*.py
scripts/check_frontend_text.py
scripts/web_health_check.py
docs
references

# --- Local config files that should not override the image's ---
docker-compose.override.yml
