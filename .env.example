# Optional CLI/API defaults for script-based usage.
# The Web UI stores provider settings in the local user config file instead.

FYADR_API_KEY=
FYADR_MODEL=
FYADR_BASE_URL=
FYADR_API_TYPE=chat_completions

# Also supported by the LLM client when FYADR_* values are empty.
OPENAI_API_KEY=
OPENAI_BASE_URL=

# --- Web server tuning (optional, all have safe defaults) ---

# --- Optional single-user web login ---
# Authentication stays disabled when all three password source variables are
# empty. Configure exactly one source for a shared/public deployment. The
# password value is only an example placeholder; use a secret manager or an
# untracked .env file in real deployments.
FYADR_AUTH_USERNAME=admin
FYADR_AUTH_PASSWORD=
FYADR_AUTH_PASSWORD_HASH=
FYADR_AUTH_PASSWORD_FILE=
# A signing key is generated under FYADR_APP_CONFIG_DIR when this is empty.
# Configure KEY or FILE, not both, only when the deployment secret store
# manages the signing material.
FYADR_AUTH_SECRET_KEY=
FYADR_AUTH_SECRET_FILE=
# Set 1 only when the service is reached through HTTPS. SameSite=None also
# requires Secure=1 when the browser UI is hosted on another site.
FYADR_AUTH_COOKIE_SECURE=0
FYADR_AUTH_COOKIE_SAMESITE=Lax
# Optional session and failed-login limiter tuning.
FYADR_AUTH_SESSION_TTL_SECONDS=43200
FYADR_AUTH_RATE_LIMIT_MAX=5
FYADR_AUTH_RATE_LIMIT_WINDOW_SECONDS=60

# Comma-separated extra CORS origins. The local dev origins
# (127.0.0.1:1420, localhost:1420, 127.0.0.1:8765, localhost:8765) are always allowed.
# Add trusted remote front-end hosts here only when needed. This is CORS, not
# authentication; it does not make the API safe to expose to untrusted networks.
FYADR_ALLOWED_ORIGINS=

# Hard cap on the total request body size (bytes). Default 67108864 (64 MiB).
FYADR_MAX_REQUEST_BYTES=

# Hard cap on a single uploaded file (bytes). Default 41943040 (40 MiB).
FYADR_MAX_UPLOAD_BYTES=

# Directory for history database backups. Empty = default location under finish/history_db_backups.
FYADR_HISTORY_BACKUP_DIR=

# Set to 1/true to skip auto-opening the browser when using start_web.bat / start_web.ps1.
FYADR_NO_BROWSER=
